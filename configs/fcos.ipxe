#!ipxe
set pxe_http pxe.boot

:menu
menu FCOS Live
item x86_64  FCOS x86_64 (live)
item aarch64 FCOS aarch64 (live)
choose target || goto menu
goto ${target}

:x86_64
kernel http://${pxe_http}/fcos/x86_64/kernel.x86_64 \
    ignition.firstboot ignition.platform.id=metal \
    coreos.live.rootfs_url=http://${pxe_http}/fcos/x86_64/rootfs.x86_64.img \
    ignition.config.url=http://${pxe_http}/ignitions/fcos-metal.ign
initrd http://${pxe_http}/fcos/x86_64/initramfs.x86_64.img
boot

:aarch64
kernel http://${pxe_http}/fcos/aarch64/kernel.aarch64 \
    ignition.firstboot ignition.platform.id=metal \
    coreos.live.rootfs_url=http://${pxe_http}/fcos/aarch64/rootfs.aarch64.img \
    ignition.config.url=http://${pxe_http}/ignitions/fcos-metal.ign
initrd http://${pxe_http}/fcos/aarch64/initramfs.aarch64.img
boot
